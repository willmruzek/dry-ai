{
  "$schema": "https://raw.githubusercontent.com/Effect-TS/language-service/refs/heads/main/schema.json",

  "compilerOptions": {
    // Runtime and module resolution
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "moduleDetection": "force",

    // Project layout
    "rootDir": "./src",
    "outDir": "./dest",

    // Emit
    "noEmit": false,
    "composite": true,
    "incremental": true,
    "sourceMap": false,
    "declarationMap": true,
    "declaration": true,

    // Type safety
    "strict": true,
    "exactOptionalPropertyTypes": true,

    // Lint-like checks
    "noUnusedLocals": true,
    "noImplicitOverride": true,

    // Import behavior and compiler ergonomics
    "verbatimModuleSyntax": true,
    "rewriteRelativeImportExtensions": true,
    "skipLibCheck": true,

    // Effect language service
    "plugins": [
      {
        "name": "@effect/language-service"
      }
    ]
  },

  "include": ["src/**/*.ts"]
}
