{
  "name": "dryai",
  "version": "2.0.0",
  "description": "CLI for installing shared AI commands, rules, and skills into Copilot and Cursor.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/willmruzek/dryai.git"
  },
  "license": "MIT",
  "files": [
    "dest/**/*.js",
    "dest/**/*.d.ts"
  ],
  "scripts": {
    "setup:editor": "effect-language-service patch",
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "dev:dryai": "node ./dest/main.js",
    "tsc": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "bin": {
    "dryai": "dest/main.js"
  },
  "dependencies": {
    "@effect/cli": "^0.75.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dedent": "^1.7.2",
    "effect": "^3.21.0",
    "fs-extra": "^11.3.4",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "simple-git": "^3.35.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@effect/language-service": "^0.85.0",
    "@effect/vitest": "^0.29.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.0.0",
    "husky": "^9.1.7",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
